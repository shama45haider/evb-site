<div id="SearchPanel" class="search-panel" aria-hidden="true">
  <div class="search-panel__overlay" data-search-close></div>
  <div class="search-panel__box" role="search">
    <form action="{{ routes.search_url }}" method="get" class="search-panel__form">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.3-4.3"/></svg>
      <input type="search" name="q" id="SearchInput" placeholder="Search products…" autocomplete="off">
      <button type="button" class="search-panel__x" data-search-close aria-label="Close">&times;</button>
    </form>
    <div id="SearchResults" class="search-panel__results"></div>
  </div>
</div>
