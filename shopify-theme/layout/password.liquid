<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ shop.name }}</title>
  <meta name="robots" content="noindex, nofollow">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@600;700;800;900&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  {{ content_for_header }}
  <style>
    * { box-sizing: border-box; }
    body {
      margin: 0; min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center;
      font-family: 'Inter', sans-serif; text-align: center; padding: 24px; color: #fff;
      background:
        radial-gradient(1200px 600px at 15% -10%, rgba(255,255,255,.25), transparent 60%),
        radial-gradient(900px 500px at 110% 110%, rgba(0,0,0,.22), transparent 55%),
        linear-gradient(150deg, #fb923c 0%, {{ settings.color_accent | default: '#f97316' }} 45%, {{ settings.color_accent_deep | default: '#b84f06' }} 100%);
    }
    .pw-logo { width: 130px; height: 130px; object-fit: contain; border-radius: 50%; background: #fff; border: 4px solid #fff; box-shadow: 0 12px 30px rgba(0,0,0,.3); margin-bottom: 24px; }
    .pw-title { font-family: 'Montserrat', sans-serif; font-weight: 900; font-size: clamp(1.6rem, 5vw, 2.6rem); text-transform: uppercase; margin: 0 0 12px; letter-spacing: -.01em; }
    .pw-sub { font-size: 15px; max-width: 460px; opacity: .95; line-height: 1.6; margin-bottom: 30px; }
    .pw-form { display: flex; gap: 10px; width: 100%; max-width: 380px; margin-bottom: 18px; }
    .pw-form input { flex: 1; padding: 13px 16px; border-radius: 9px; border: none; font: inherit; }
    .pw-form button {
      padding: 13px 22px; border-radius: 9px; border: none; background: #14100c; color: #fff;
      font-family: 'Montserrat', sans-serif; font-weight: 800; font-size: 12px; letter-spacing: .06em; text-transform: uppercase; cursor: pointer;
    }
    .pw-error { color: #fff; background: rgba(0,0,0,.25); padding: 8px 14px; border-radius: 8px; font-size: 13px; margin-bottom: 14px; }
    .pw-foot { margin-top: 34px; font-size: 12.5px; opacity: .85; }
    .pw-foot a { color: #fff; text-decoration: underline; }
  </style>
</head>
<body>
  {% if settings.logo %}
    <img src="{{ settings.logo | image_url: width: 260 }}" alt="{{ shop.name }}" class="pw-logo">
  {% endif %}
  <h1 class="pw-title">{{ shop.name }}</h1>
  <p class="pw-sub">We're getting things ready. Enter the password below for early access, or check back soon.</p>

  {% form 'storefront_password' %}
    {% if form.errors %}
      <div class="pw-error">{{ 'general.password_page.login_form_error' | t | default: 'Wrong password, try again.' }}</div>
    {% endif %}
    <div class="pw-form">
      <input type="password" name="password" placeholder="Password" required>
      <button type="submit">Enter</button>
    </div>
  {% endform %}

  <p class="pw-foot">
    39 Avenue A, New York, NY 10009
    {% if settings.instagram_url != blank %} &middot; <a href="{{ settings.instagram_url }}" target="_blank" rel="noopener">Instagram</a>{% endif %}
  </p>

  {{ content_for_layout }}
</body>
</html>
