    "settings": [
      { "type": "color", "id": "color_accent", "label": "Accent (orange)", "default": "#f97316" },
      { "type": "color", "id": "color_accent_dark", "label": "Accent dark", "default": "#e8690a" },
      { "type": "color", "id": "color_accent_deep", "label": "Accent deep (button shadow)", "default": "#b84f06" },
      { "type": "color", "id": "color_green", "label": "Secondary green (VILLAGE accent)", "default": "#1e7d32" },
      { "type": "color", "id": "color_ink", "label": "Text", "default": "#1a1814" },
      { "type": "color", "id": "color_paper", "label": "Background", "default": "#f8f5f0" },
      { "type": "color", "id": "color_line", "label": "Border", "default": "#e8e4de" },
      { "type": "color", "id": "color_card", "label": "Card background", "default": "#ffffff" }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "paragraph",
        "content": "Fonts are locked to Montserrat (headings), Inter (body), and Bebas Neue (display accents) to match eastvillagebuyers.com exactly."
      }
    ]
  },
  {
    "name": "Logo",
    "settings": [
      { "type": "image_picker", "id": "logo", "label": "Logo image" },
      { "type": "range", "id": "logo_width", "label": "Header logo size", "min": 60, "max": 160, "step": 5, "default": 90, "unit": "px" },
      { "type": "range", "id": "logo_width_footer", "label": "Footer logo size", "min": 80, "max": 220, "step": 10, "default": 130, "unit": "px" },
      { "type": "checkbox", "id": "logo_badge_frame", "label": "Show circular badge frame behind header logo", "default": true }
    ]
  },
  {
    "name": "Store info",
    "settings": [
      { "type": "text", "id": "store_address", "label": "Address", "default": "39 Avenue A, New York, NY 10009" },
      { "type": "text", "id": "store_phone", "label": "Phone", "default": "917-608-8939" },
      { "type": "text", "id": "store_hours", "label": "Hours", "default": "Sun 12:30–6 PM · Mon–Thu 12:30–6:30 PM · Fri 12:30–6 PM · Sat Closed" },
      { "type": "text", "id": "sms_link", "label": "Text-us link", "default": "sms:9176088939" },
      { "type": "url", "id": "instagram_url", "label": "Instagram URL" },
      { "type": "url", "id": "tiktok_url", "label": "TikTok URL" },
      { "type": "url", "id": "google_url", "label": "Google reviews URL" },
      { "type": "text", "id": "main_site_url", "label": "Main website URL", "default": "https://eastvillagebuyers.com" }
    ]
  },
  {
    "name": "Buttons",
    "settings": [
      { "type": "range", "id": "button_radius", "label": "Corner radius", "min": 0, "max": 30, "step": 1, "default": 9, "unit": "px" },
      { "type": "checkbox", "id": "button_pulse", "label": "Pulse animation on primary CTA buttons", "default": true }
    ]
  },
  {
    "name": "Mobile",
    "settings": [
      { "type": "checkbox", "id": "sticky_mobile_cta", "label": "Show sticky Call/Text bar on mobile", "default": true }
    ]
  },
  {
    "name": "Product cards",
    "settings": [
      { "type": "select", "id": "card_image_ratio", "label": "Image shape", "options": [
        { "value": "square", "label": "Square" },
        { "value": "portrait", "label": "Portrait" }
      ], "default": "square" },
      { "type": "checkbox", "id": "card_show_vendor", "label": "Show brand on cards", "default": true }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      { "type": "select", "id": "cart_type", "label": "Cart behavior", "options": [
        { "value": "page", "label": "Cart page" },
        { "value": "drawer", "label": "Cart drawer" }
      ], "default": "drawer" }
    ]
  }
]
