<section class="reviews-strip">
  <div class="reviews-strip__inner">
    <svg class="reviews-strip__g" viewBox="0 0 24 24" width="26" height="26"><path fill="#4285F4" d="M21.6 12.2c0-.7-.1-1.4-.2-2H12v3.9h5.4a4.6 4.6 0 0 1-2 3v2.5h3.2c1.9-1.7 3-4.3 3-7.4z"/><path fill="#34A853" d="M12 22c2.7 0 5-.9 6.6-2.4l-3.2-2.5c-.9.6-2 1-3.4 1a5.9 5.9 0 0 1-5.6-4.1H3.1v2.6A10 10 0 0 0 12 22z"/><path fill="#FBBC05" d="M6.4 14a6 6 0 0 1 0-4.1V7.3H3.1a10 10 0 0 0 0 9.3z"/><path fill="#EA4335" d="M12 6a5.4 5.4 0 0 1 3.8 1.5l2.8-2.8A9.6 9.6 0 0 0 12 2a10 10 0 0 0-8.9 5.3l3.3 2.6A5.9 5.9 0 0 1 12 6z"/></svg>
    <div class="reviews-strip__stars">
      {% for i in (1..5) %}<svg viewBox="0 0 24 24" width="16" height="16" fill="#f5a623"><path d="M12 2l3.1 6.3 6.9 1-5 4.9 1.2 6.9-6.2-3.3-6.2 3.3 1.2-6.9-5-4.9 6.9-1z"/></svg>{% endfor %}
    </div>
    <span class="reviews-strip__text">{{ section.settings.rating }} out of 5 &middot; {{ section.settings.count }} Google reviews</span>
    {% if settings.google_url != blank %}
      <a href="{{ settings.google_url }}" target="_blank" rel="noopener" class="reviews-strip__link">Read Reviews &rarr;</a>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Google reviews strip",
  "settings": [
    { "type": "text", "id": "rating", "label": "Rating", "default": "4.9" },
    { "type": "text", "id": "count", "label": "Review count", "default": "500+" }
  ],
  "presets": [{ "name": "Google reviews strip" }]
}
{% endschema %}
