<section class="hero-shop">
  <div class="hero-shop__inner">

    <div class="hero-shop__copy">
      <h1 class="hero-shop__title">
        {%- if section.settings.heading_accent != blank -%}
          {%- assign accent_html = section.settings.heading_accent | prepend: '<em>' | append: '</em>' -%}
          {{ section.settings.heading | replace: section.settings.heading_accent, accent_html }}
        {%- else -%}
          {{ section.settings.heading }}
        {%- endif -%}
      </h1>

      {% if section.settings.subheading != blank %}
        <p class="hero-shop__sub">{{ section.settings.subheading }}</p>
      {% endif %}

      <div class="hero-shop__actions">
        {% if section.settings.cta_text != blank %}
          <a href="{{ section.settings.cta_link | default: '/collections/all' }}" class="btn btn--solid btn--lg {% if settings.button_pulse %}btn--pulse{% endif %}">{{ section.settings.cta_text }}</a>
        {% endif %}
        {% if section.settings.link_text != blank %}
          <a href="{{ section.settings.link_link | default: '#section-visit' }}" class="hero-shop__link">
            {{ section.settings.link_text }}
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        {% endif %}
      </div>
    </div>

    <div class="hero-shop__media">
      {% if section.settings.hero_image %}
        <img src="{{ section.settings.hero_image | image_url: width: 1000 }}" alt="{{ section.settings.image_alt | default: shop.name | escape }}" class="hero-shop__photo" width="1000" height="750">
      {% else %}
        <img src="{{ 'evbstorefront.webp' | asset_url }}" alt="{{ section.settings.image_alt | default: shop.name | escape }}" class="hero-shop__photo" width="1000" height="750">
      {% endif %}
    </div>

  </div>

  {% if section.settings.marquee_items != blank %}
    {% assign marquee_list = section.settings.marquee_items | split: ',' %}
    <div class="hero-shop__marquee">
      <div class="hero-shop__marquee-track">
        {% for i in (1..2) %}
          {% for item in marquee_list %}
            <span>{{ item | strip }}</span>
            <span class="hero-shop__marquee-dot">&bull;</span>
          {% endfor %}
        {% endfor %}
      </div>
    </div>
  {% endif %}

</section>

{% schema %}
{
  "name": "Hero banner",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "East Village Buyers Official Online Store" },
    { "type": "text", "id": "heading_accent", "label": "Accent word/phrase in heading", "info": "Must match text in the heading exactly. Leave blank for none.", "default": "Official Online Store" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Authenticated gold, jewelry, streetwear, sneakers, and collectibles — shipped nationwide within 2 business days from our East Village shop." },
    { "type": "text", "id": "cta_text", "label": "Primary button text", "default": "Shop All Products" },
    { "type": "url", "id": "cta_link", "label": "Primary button link" },
    { "type": "text", "id": "link_text", "label": "Secondary link text", "default": "Visit Us in the East Village" },
    { "type": "url", "id": "link_link", "label": "Secondary link URL" },
    { "type": "header", "content": "Hero image" },
    { "type": "image_picker", "id": "hero_image", "label": "Hero image", "info": "Defaults to the bundled storefront photo." },
    { "type": "text", "id": "image_alt", "label": "Image alt text", "default": "East Village Buyers storefront on Avenue A" },
    { "type": "header", "content": "Scrolling strip" },
    { "type": "text", "id": "marquee_items", "label": "Marquee items (comma-separated)", "default": "Authenticated In-Store, Fast Tracked Shipping, New Drops Weekly, Same-Day Cash Offers" }
  ],
  "presets": [{ "name": "Hero banner" }]
}
{% endschema %}
