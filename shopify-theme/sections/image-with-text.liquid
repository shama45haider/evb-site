<section class="section image-with-text {% if section.settings.layout == 'right' %}image-with-text--reverse{% endif %}">
  <div class="image-with-text__inner">
    <div class="image-with-text__media">
      {% if section.settings.image %}
        <img src="{{ section.settings.image | image_url: width: 900 }}" alt="{{ section.settings.heading | escape }}" loading="lazy" width="900" height="700">
      {% elsif section.settings.fallback_image != blank %}
        <img src="{{ section.settings.fallback_image | asset_url }}" alt="{{ section.settings.heading | escape }}" loading="lazy" width="900" height="700">
      {% else %}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'image-with-text__placeholder' }}
      {% endif %}
    </div>
    <div class="image-with-text__body">
      {% if section.settings.eyebrow != blank %}<span class="image-with-text__eyebrow">{{ section.settings.eyebrow }}</span>{% endif %}
      <h2>{{ section.settings.heading }}</h2>
      <div class="image-with-text__rte">{{ section.settings.text }}</div>
      {% if section.settings.btn_text != blank %}
        <a href="{{ section.settings.btn_link }}" class="btn btn--solid">{{ section.settings.btn_text }}</a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Image with text",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "fallback_image", "label": "Bundled fallback image filename (advanced, optional)" },
    { "type": "select", "id": "layout", "label": "Image position", "options": [
      { "value": "left", "label": "Left" },
      { "value": "right", "label": "Right" }
    ], "default": "left" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Why Sell to Us" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>We evaluate everything in person, pay cash the same day, and never ship your items away for grading.</p>" },
    { "type": "text", "id": "btn_text", "label": "Button text" },
    { "type": "url", "id": "btn_link", "label": "Button link" }
  ],
  "presets": [{ "name": "Image with text" }]
}
{% endschema %}
