<section class="section visit-us" id="section-visit">
  <div class="section__inner visit-us__inner">
    <div class="visit-us__body">
      <span class="process-steps__eyebrow">{{ section.settings.eyebrow }}</span>
      <h2 class="section__title">{{ section.settings.heading }}</h2>
      <p class="visit-us__text">{{ section.settings.text }}</p>

      <div class="visit-us__info">
        <div class="visit-us__row">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/><circle cx="12" cy="9" r="2.5"/></svg>
          <span>{{ settings.store_address }}</span>
        </div>
        <div class="visit-us__row">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <span>{{ settings.store_hours }}</span>
        </div>
        <div class="visit-us__row">
          <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/></svg>
          <span>{{ settings.store_phone }}</span>
        </div>
      </div>

      <div class="visit-us__btns">
        <a href="tel:{{ settings.store_phone | remove: '-' }}" class="btn btn--solid {% if settings.button_pulse %}btn--pulse{% endif %}">Call Now</a>
        {% if settings.sms_link != blank %}<a href="{{ settings.sms_link }}" class="btn btn--ghost">Text Us</a>{% endif %}
        <a href="https://maps.google.com/?q={{ settings.store_address | url_encode }}" target="_blank" rel="noopener" class="btn btn--ghost">Get Directions</a>
      </div>
    </div>

    <div class="visit-us__map">
      <iframe
        src="https://maps.google.com/maps?q={{ settings.store_address | url_encode }}&t=&z=15&ie=UTF8&iwloc=&output=embed"
        loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Store location map">
      </iframe>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Visit us",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "COME SEE US" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Visit East Village Buyers" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Walk in anytime during store hours — no appointment needed. We evaluate every item in person and pay cash on the spot." }
  ],
  "presets": [{ "name": "Visit us" }]
}
{% endschema %}
