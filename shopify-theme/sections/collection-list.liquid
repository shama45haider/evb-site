<section class="section collection-slider" id="section-shop">
  <div class="section__inner">
    <div class="section__head">
      <h2 class="section__title">{{ section.settings.heading }}</h2>
      {% if section.blocks.size > 4 %}
        <div class="slider-arrows">
          <button type="button" class="slider-arrow" data-slider-prev aria-label="Previous">&#8249;</button>
          <button type="button" class="slider-arrow" data-slider-next aria-label="Next">&#8250;</button>
        </div>
      {% endif %}
    </div>
    <div class="collection-slider__track" data-slider-track>
      {% for block in section.blocks %}
        {% assign col = block.settings.collection %}
        <a href="{{ col.url | default: '#' }}" class="collection-tile" {{ block.shopify_attributes }}>
          <div class="collection-tile__media">
            {% if col.image %}
              <img src="{{ col.image | image_url: width: 500 }}" alt="{{ col.title | escape }}" loading="lazy" width="500" height="500">
            {% elsif block.settings.image %}
              <img src="{{ block.settings.image | image_url: width: 500 }}" alt="{{ block.settings.title | escape }}" loading="lazy" width="500" height="500">
            {% elsif block.settings.fallback_image != blank %}
              <img src="{{ block.settings.fallback_image | asset_url }}" alt="{{ block.settings.title | escape }}" loading="lazy" width="500" height="500">
            {% else %}
              {{ 'collection-1' | placeholder_svg_tag: 'collection-tile__placeholder' }}
            {% endif %}
          </div>
          <div class="collection-tile__title">{{ block.settings.title | default: col.title }}</div>
          {% if col != blank %}<div class="collection-tile__count">{{ col.products_count }} items</div>{% endif %}
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Shop by collection",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by Collection"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection tile",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Custom title (optional)"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom image (optional, overrides collection image)"
        },
        {
          "type": "text",
          "id": "fallback_image",
          "label": "Bundled fallback image filename (advanced, optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop by collection"
    }
  ]
}
{% endschema %}
